{
  "name": "arcane-siege-portmanteau-duels",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "Arcane Siege: Portmanteau Duels — a deterministic, local hot-seat two-player wizard card duel. Mechanics based on Castle Wars, rethemed as an original game inspired by Magic & Mayhem.",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc -b --noEmit",
    "art": "node --env-file=src/.env.local scripts/generate-art.mjs",
    "sfx": "node --env-file=src/.env.local scripts/generate-sfx.mjs",
    "video": "node --env-file=src/.env.local scripts/generate-video.mjs",
    "cutout": "node --env-file=src/.env.local scripts/cutout.mjs",
    "optimize": "node scripts/optimize-art.mjs"
  },
  "dependencies": {
    "@fontsource/cinzel": "^5.2.8",
    "@fontsource/eb-garamond": "^5.2.7",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "sharp": "^0.34.5",
    "typescript": "^5.6.3",
    "vite": "^5.4.11",
    "vitest": "^2.1.8"
  }
}
